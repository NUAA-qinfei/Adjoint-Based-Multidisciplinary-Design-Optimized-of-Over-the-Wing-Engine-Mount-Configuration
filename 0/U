FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];


internalField   uniform (233.6721507 11.22407828 0);

boundaryField
{
    hot
    {
        type            fixedValue;
        value           uniform (260.84 -0.0007 -0.0012);
    }
    cold
    {
        type            fixedValue;
        value           uniform (134.08 0.001 0.0015);
    }
    in
    {
        type            inletOutlet;
        inletValue      uniform (168.72 -0.66 -1.8);
        value           uniform (168.71 -0.66 -1.8);
    }
    wing
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    far
    {
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    }
    sym
    {
        type            symmetry;
    }
}


